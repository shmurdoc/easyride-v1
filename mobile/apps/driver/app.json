{
  "expo": {
    "name": "EasyRyde Driver",
    "slug": "easyryde-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "za.co.easyryde.driver",
      "config": {
        "googleMapsApiKey": "AIzaSyDXcaUumZ7RJkaXpqUa2IYhSU3xxJSLvAw"
      }
    },
    "android": {
      "package": "za.co.easyryde.driver",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDXcaUumZ7RJkaXpqUa2IYhSU3xxJSLvAw"
        }
      }
    },
    "plugins": [
      "expo-location",
      [
        "react-native-maps",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow EasyRyde to track your location for ride requests."
        }
      ]
    ]
  }
}
