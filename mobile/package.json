{
  "name": "easyryde-mobile",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "nohoist": [
      "**/babel-preset-expo",
      "**/expo",
      "**/expo-*",
      "**/expo-**",
      "**/react-native",
      "**/react-native-*",
      "**/@react-native/**",
      "**/@react-native-community/**",
      "**/@expo/**"
    ]
  },
  "scripts": {
    "rider": "cd apps/rider && npx expo start",
    "driver": "cd apps/driver && npx expo start",
    "admin": "cd apps/admin && npx expo start",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "graphql": "^17.0.1",
    "md5-file": "^4.0.0",
    "nanoid": "^3.3.12",
    "react-native-maps": "^1.14.0",
    "sucrase": "^3.35.1"
  }
}
