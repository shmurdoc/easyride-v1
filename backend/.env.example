# WARNING: Never commit the actual .env file! Copy this to .env and fill in values.

# --- Application ---
APP_NAME=EasyRyde
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_PREVIOUS_KEYS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# --- Database ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=easyryde
DB_USERNAME=easyryde
DB_PASSWORD=changeme
DB_SSLMODE=prefer
# DB_URL=
# DB_SOCKET=
# DB_CHARSET=utf8
# DB_COLLATION=utf8_unicode_ci
# DB_FOREIGN_KEYS=true
# MYSQL_ATTR_SSL_CA=

# --- Redis ---
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_USERNAME=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=easyryde_
# REDIS_URL=
# REDIS_PERSISTENT=false
# REDIS_CLUSTER=redis
# REDIS_MAX_RETRIES=3
# REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
# REDIS_BACKOFF_BASE=100
# REDIS_BACKOFF_CAP=1000
# REDIS_QUEUE_CONNECTION=default
# REDIS_QUEUE=default
# REDIS_QUEUE_RETRY_AFTER=90
# REDIS_CACHE_CONNECTION=cache
# REDIS_CACHE_LOCK_CONNECTION=default

# --- Session ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
# SESSION_CONNECTION=
# SESSION_TABLE=sessions
# SESSION_STORE=
# SESSION_EXPIRE_ON_CLOSE=false
# SESSION_PARTITIONED_COOKIE=false

# --- Cache ---
CACHE_STORE=redis
CACHE_PREFIX=easyryde_cache_
# DB_CACHE_CONNECTION=
# DB_CACHE_TABLE=cache
# DB_CACHE_LOCK_CONNECTION=
# DB_CACHE_LOCK_TABLE=
# CACHE_STORAGE_DISK=
# CACHE_STORAGE_PATH=framework/cache/data
# MEMCACHED_HOST=127.0.0.1
# MEMCACHED_PORT=11211
# MEMCACHED_USERNAME=
# MEMCACHED_PASSWORD=
# MEMCACHED_PERSISTENT_ID=
# DYNAMODB_CACHE_TABLE=cache
# DYNAMODB_ENDPOINT=

# --- Logging ---
LOG_CHANNEL=stderr
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null
LOG_DAILY_DAYS=14
# LOG_DEPRECATIONS_TRACE=false
# LOG_STDERR_FORMATTER=
# LOG_SENTRY_FORMATTER=

# --- Sentry ---
# Get your DSN from https://easyryde.sentry.io/settings/projects/<project>/keys/
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.25
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# --- Mail ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@easyryde.com"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_SCHEME=
# MAIL_URL=
# MAIL_EHLO_DOMAIN=
# MAIL_SENDMAIL_PATH=/usr/sbin/sendmail -bs -i
# MAIL_LOG_CHANNEL=
# POSTMARK_MESSAGE_STREAM_ID=

# --- Queue ---
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
# DB_QUEUE_CONNECTION=
# DB_QUEUE_TABLE=jobs
# DB_QUEUE=default
# DB_QUEUE_RETRY_AFTER=90
# BEANSTALKD_QUEUE_HOST=localhost
# BEANSTALKD_QUEUE=default
# BEANSTALKD_QUEUE_RETRY_AFTER=90
# SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id
# SQS_QUEUE=default
# SQS_SUFFIX=

# --- Broadcasting ---
BROADCAST_CONNECTION=redis

# --- Filesystem ---
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=
SANCTUM_TOKEN_EXPIRATION=10080
SANCTUM_TOKEN_PREFIX=er_

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://your-domain.com

# --- Horizon ---
# HORIZON_DOMAIN=
HORIZON_PATH=horizon

# --- Stripe ---
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- PayFast ---
# PAYFAST_MERCHANT_ID=
# PAYFAST_MERCHANT_KEY=
# PAYFAST_PASSPHRASE=
# PAYFAST_MODE=sandbox
# PAYFAST_RETURN_URL=https://your-domain.com/payments/payfast/return
# PAYFAST_CANCEL_URL=https://your-domain.com/payments/payfast/cancel
# PAYFAST_NOTIFY_URL=https://your-domain.com/api/v1/payments/payfast/webhook

# --- Ozow ---
# OZOW_SITE_CODE=
# OZOW_API_KEY=
# OZOW_PRIVATE_KEY=
# OZOW_MODE=sandbox
# OZOW_COUNTRY_CODE=ZA
# OZOW_CURRENCY_CODE=ZAR
# OZOW_NOTIFY_URL=https://your-domain.com/api/v1/payments/ozow/webhook
# OZOW_RETURN_URL=https://your-domain.com/payments/ozow/return
# OZOW_CANCEL_URL=https://your-domain.com/payments/ozow/cancel

# --- Postmark ---
# POSTMARK_API_KEY=

# --- Resend ---
# RESEND_API_KEY=

# --- Slack ---
# SLACK_BOT_USER_OAUTH_TOKEN=
# SLACK_BOT_USER_DEFAULT_CHANNEL=

# --- Firebase / FCM ---
# FCM_PROJECT_ID=easyryde-625a7
# FCM_SERVICE_ACCOUNT_PATH=storage/firebase-service-account.json

# --- Twilio (SMS) ---
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# --- Authentication ---
# AUTH_GUARD=web
# AUTH_PASSWORD_BROKER=users
# AUTH_MODEL=App\Models\User
# AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
# AUTH_PASSWORD_TIMEOUT=10800

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"
