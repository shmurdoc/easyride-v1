{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      "C:/Users/dzong/.config/opencode/skills"
    ]
  },
  "mcp": {
    "ruflo": {
      "type": "local",
      "command": ["npx", "-y", "ruflo", "mcp", "start"],
      "enabled": true
    }
  },
  "agent": {
    "ceo": { "description": "Strategic direction and decomposition" },
    "eng-manager": { "description": "Planning and execution framing" },
    "designer": { "description": "UX and product-design decisions" },
    "builder": { "description": "Implementation execution" },
    "reviewer": { "description": "Code quality and review" },
    "debugger": { "description": "Root-cause analysis and fixes" },
    "qa-lead": { "description": "Test strategy and quality assurance" },
    "release-engineer": { "description": "Release readiness and publishing flow" },
    "doc-engineer": { "description": "Documentation and handoff quality" }
  }
}
