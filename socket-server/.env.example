# Server
PORT=3001
CLIENT_URL=http://localhost:8000

# JWT
JWT_SECRET=your-secure-jwt-secret-here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Location
STALE_LOCATION_TTL=300
CLEANUP_INTERVAL_MS=60000
DRIVER_RADIUS_KM=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# Logging
LOG_LEVEL=info
